// This is your Prisma schema file.
// Configure access to Vercel Postgres using DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============
// ENUMS
// ==============
enum Role {
  USER
  ADMIN
}

// ==============
// NEXTAUTH V5 MODELS
// ==============

model User {
  id               String          @id @default(cuid())
  name             String?
  email            String?         @unique
  emailVerified    DateTime?
  image            String?
  role             Role            @default(USER)
  hasWelcomeCoupon Boolean         @default(false)
  accounts         Account[]
  sessions      Session[]
  
  // Custom Relations
  generatedAssets GeneratedAsset[]
  storeOrders     StoreOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ==============
// CUSTOM BUSINESS MODELS
// ==============

enum GenerationStatus {
  PENDING
  COMPLETE
  FAILED
}

model GeneratedAsset {
  id                 String   @id @default(cuid())
  userId             String
  originalImage      String?  @db.Text
  resultImage        String?  @db.Text
  backImage          String?  @db.Text
  sideImage          String?  @db.Text
  prompt             String?  @db.Text
  baseModelVariantId String?
  status             GenerationStatus @default(COMPLETE) // Default true for legacy, handled in code
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model StoreOrder {
  id             String   @id @default(cuid())
  shopifyOrderId String   @unique
  userId         String
  status         String   // "placed", "fulfilled", "cancelled"
  trackingUrl    String?  @db.Text
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
